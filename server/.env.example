# Copy to server/.env

# MongoDB connection string (required)
MONGODB_URI=mongodb://localhost:27017/edu_arena

# JWT secret (required)
# You can also reuse SECRET_KEY from the root .env
JWT_SECRET=change-me
JWT_EXPIRES_IN=1d

# Optional: seed teacher account for quick testing
ADMIN_EMAIL=teacher@example.com
ADMIN_PASSWORD=ChangeMe123
TEACHER_FULL_NAME=Mr. Teacher

# CORS
CORS_ORIGIN=http://localhost:5173
PORT=8000

